# ---- 写真保管（Cloudinary） ----
# どちらかの方法で設定。未設定でもローカル保存で動きます（本番はCloudinary推奨）。
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# もしくは個別に:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=doteppan-open-check

# ---- 未オープンアラート（LINE Messaging API・任意） ----
# 自分専用の通知用LINE公式アカウントを作り、友だち追加して userId を取得して設定
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_ID=

# ---- DB（Railwayが自動で入れます。ローカルは未設定=sqlite） ----
# DATABASE_URL=postgresql://...

# ---- 認証 ----
ADMIN_PASSCODE=0
SECRET_KEY=please-change-this-to-a-random-string
